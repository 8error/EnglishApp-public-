<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- 工具栏 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_500"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- 设置内容 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 标题：每日复习设置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="每日复习设置"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/purple_500"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- 每日复习数量 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="每日复习单词数量"
                android:textSize="16sp"
                android:textColor="@android:color/black"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@android:color/white"
                android:padding="8dp"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/et_daily_review_count"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:hint="例如：20"
                    android:textSize="16sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@android:drawable/editbox_background" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个"
                    android:textSize="16sp"
                    android:textColor="@android:color/black"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@android:color/darker_gray"
                android:layout_marginVertical="16dp" />

            <!-- 标题：复习策略 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="复习策略"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/purple_500"
                android:layout_marginBottom="16dp" />

            <!-- 复习策略选项 -->
            <RadioGroup
                android:id="@+id/rg_review_strategy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/rb_strict"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="严格模式"
                    android:textSize="16sp"
                    android:textColor="@android:color/black"
                    android:paddingVertical="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="· 严格按照每日设定的数量复习\n· 超过数量的单词自动推迟到明天"
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginStart="32dp"
                    android:layout_marginBottom="12dp"
                    android:lineSpacingExtra="4dp" />

                <RadioButton
                    android:id="@+id/rb_flexible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="灵活模式"
                    android:textSize="16sp"
                    android:textColor="@android:color/black"
                    android:paddingVertical="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="· 显示所有需要复习的单词\n· 用户可以自由选择复习哪些单词"
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginStart="32dp"
                    android:lineSpacingExtra="4dp" />

            </RadioGroup>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@android:color/darker_gray"
                android:layout_marginVertical="16dp" />

            <!-- 标题：复习行为 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="复习行为"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/purple_500"
                android:layout_marginBottom="16dp" />

            <!-- 自动下一个选项 -->
            <CheckBox
                android:id="@+id/cb_auto_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="标记后自动进入下一个单词"
                android:textSize="16sp"
                android:textColor="@android:color/black"
                android:paddingVertical="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开启后，点击「记住」或「忘记」会自动跳转到下一个单词"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="24dp" />

            <!-- 保存按钮 -->
            <Button
                android:id="@+id/btn_save_settings"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="保存设置"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/purple_500"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>